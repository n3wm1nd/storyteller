-- | Integration suite for agent *quality*, not mechanics: real
-- 'Storyteller.Core.Runtime.StoryModel' calls (cached to disk via
-- 'Runix.LLM.Cache', see @test/fixtures/llm-agent-cache/@), checking whether
-- context is actually used, edits are actually targeted, etc. -- properties
-- @storyteller-test@'s mocked LLM-free specs can't reach.
--
-- A plain @executable@, not a @test-suite@, even though @Main.hs@ just
-- calls 'Test.Hspec.hspec' -- deliberately: a @test-suite@ component is
-- exactly what @cabal test@ (with no target) runs by default, and this one
-- shouldn't be swept up in that (hits real models, needs network/API keys,
-- can take minutes). Being an @executable@ means @cabal test@/@cabal build
-- all@ never touch it; run it with
-- @cabal run storyteller-agent-integration-test@ (pass hspec args after
-- @--@, e.g. @-- --match "..."@).
executable storyteller-agent-integration-test
  main-is:          Main.hs
  other-modules:    Agent.Integration.Harness
                  , Agent.Integration.Judge
                  , Agent.Integration.Journey
                  , Agent.Integration.CharContextWriteSpec
                  , Agent.Integration.ReworkAtomSpec
                  , Agent.Integration.JourneySpec
                  , Agent.Integration.OutlineSplitQualitySpec
                  , Agent.Integration.OutlineSplitDefaultsSpec
                  , Agent.Integration.OutlineSplitEscapingSpec
                  , Agent.Integration.OutlineSplitCheck
                  , Agent.Integration.OutlineSplitFreeformSpec
                  , Agent.Integration.OutlineSplitBulkSpec
                  , Agent.Integration.CharacterPresenceSpec
                  , Agent.Integration.WorldLoreSpec
                  , Agent.Integration.JournalInstructionSpec
                  , Agent.Integration.JournalIronySpec
                  , Agent.Integration.WriterStyleGuideSpec
                  , Agent.Integration.WriterPinnedContextSpec
                  , Agent.Integration.WriterEarlierChaptersSpec
                  , Agent.Integration.WriterConversationHistorySpec
                  , Agent.Integration.TasksSteeringSpec
                  , Agent.Integration.TasksSuggestionQualitySpec
                  , Agent.Integration.TasksReconcileSpec
                  , Agent.Integration.ToolCallQuality
                  , Git.Mock
                  , Paths_storyteller
  autogen-modules:  Paths_storyteller
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , text
                  , bytestring
                  , runix
                  , universal-llm
                  , hspec >=2.11
                  , aeson
                  , autodocodec
                  , data-default
                  , containers
                  , hashable
  hs-source-dirs:   test/agent-integration, test
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -fplugin=Polysemy.Plugin

-- | Scaling probe for the At/updateReferences cascade cost (see
-- bench/PerfCascade.hs). Not a correctness test: scaling badly is a
-- performance fact to observe via 'cabal bench', not a build failure.
benchmark storyteller-cascade-perf
  type:             exitcode-stdio-1.0
  main-is:          PerfCascade.hs
  other-modules:    Git.Mock
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , containers
                  , text
                  , bytestring
                  , runix
                  , hashable
  hs-source-dirs:   bench, test
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2
                    -fplugin=Polysemy.Plugin

-- | Diagnostic: reproduce a real-git-backed edit deep in history (not
-- Git.Mock) to isolate whether the remaining cost after the storage-monad
-- migration is git-subprocess-call count rather than Polysemy dispatch.
-- Not a correctness check; never fails the build.
benchmark real-git-perf
  type:             exitcode-stdio-1.0
  main-is:          RealGitPerf.hs
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , containers
                  , text
                  , runix
  hs-source-dirs:   bench
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2
                    -fplugin=Polysemy.Plugin

-- | Reproduces the live merge.atoms/split.atoms report directly: real
-- Storage.Ops.mergeAtoms/splitTick, real tracker branches, one
-- persistently-open interpreter per backend across repeated requests --
-- see MergeSplitPerf.hs's own doc for why this differs from
-- gitlib-effect's synthetic linear-chain benches. Not a correctness
-- check; never fails the build.
benchmark storyteller-mergesplit-perf
  type:             exitcode-stdio-1.0
  main-is:          MergeSplitPerf.hs
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , containers
