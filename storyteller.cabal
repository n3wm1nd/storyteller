cabal-version:      3.0
name:               storyteller
version:            0.1.0.0
synopsis:           LLM-powered story development system
description:        Storyteller treats narrative as queryable, versioned state,
                    combining git version control, hierarchical summarization,
                    and character knowledge tracking.
license:            MIT
author:             storyteller authors
maintainer:         authors@storyteller.dev
category:           Development
build-type:         Simple

library
  exposed-modules:  Storyteller
                  , Storyteller.Types
                  , Storyteller.Storage
  other-modules:
  build-depends:    base >=4.18 && <5
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , polysemy
                  , template-haskell
  hs-source-dirs:   src
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -O2

executable storyteller
  main-is:          Main.hs
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , text
  hs-source-dirs:   app
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2

test-suite storyteller-test
  type:             exitcode-stdio-1.0
  main-is:          Main.hs
  build-depends:    base >=4.18 && <5
                  , storyteller
  hs-source-dirs:   test
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
