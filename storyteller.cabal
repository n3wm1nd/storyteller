                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -O2

-- ---------------------------------------------------------------------------
-- Executables
-- ---------------------------------------------------------------------------

common exe-common
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , gitlib-effect
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , polysemy
                  , polysemy-plugin
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2
                    -fplugin=Polysemy.Plugin

-- | Append a generated story section.
executable story-write
  import:           exe-common
  main-is:          Write.hs
  hs-source-dirs:   app

-- | Expand a story outline into a chapter beat sheet.
executable story-outline
  import:           exe-common
  main-is:          Outline.hs
  hs-source-dirs:   app

-- | Generate a chapter's prose from its beat sheet.
executable story-chapter
  import:           exe-common
  main-is:          Chapter.hs
  hs-source-dirs:   app

-- | Copy atoms from a source branch into an entity/tracker branch.
executable story-track
  import:           exe-common
  main-is:          Track.hs
  hs-source-dirs:   app

-- | Split working-tree diffs and merge them into the chain at the right positions.
executable story-rebase
  import:           exe-common
  main-is:          Rebase.hs
  hs-source-dirs:   app

-- | Resolve a scenario template into a character sheet and commit it to an entity branch.
executable story-chargen
  import:           exe-common
  main-is:          CharGen.hs
  hs-source-dirs:   app
  build-depends:    yaml
                  , random


-- | WebSocket server.
executable story-server
  import:           exe-common
  main-is:          Server.hs
  hs-source-dirs:   app
  build-depends:    wai
                  , warp
                  , websockets
                  , wai-websockets
                  , http-types
                  , filepath
                  , directory

