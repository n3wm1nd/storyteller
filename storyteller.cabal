cabal-version:      3.0
name:               storyteller
version:            0.1.0.0
synopsis:           LLM-powered story development system
description:        Storyteller treats narrative as queryable, versioned state,
                    combining git version control, hierarchical summarization,
                    and character knowledge tracking.
license:            MIT
author:             storyteller authors
maintainer:         authors@storyteller.dev
category:           Development
build-type:         Simple
data-files:         test/fixtures/minimal.yaml

-- | General-purpose git effect + libgit2 interpreter.
--   Intended to migrate to runix proper once stable.
library gitlib-effect
  exposed-modules:  Runix.Git
  build-depends:    base >=4.18 && <5
                  , polysemy
                  , text
                  , bytestring
                  , runix
  hs-source-dirs:   gitlib-effect/src
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs

library
  exposed-modules:  Storyteller
                  , Storyteller.Types
                  , Storyteller.Storage
                  , Storyteller.Git
                  , Storyteller.Runtime
                  , Storyteller.CLI.Env
                  , Storyteller.Agent.Continuation
                  , Storyteller.Agent.CharContext
                  , Storyteller.Agent.Splitter
                  , Storyteller.Agent.Tracker
                  , Storyteller.Agent.SplitDiffMerge
                  , Storyteller.Agent.CharGen
                  , Storyteller.Agent.Append
                  , Storyteller.Agent.Write
  other-modules:
  build-depends:    base >=4.18 && <5
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , filepath
                  , polysemy
                  , template-haskell
                  , storyteller:gitlib-effect
                  , polysemy-plugin
                  , aeson
                  , scientific
                  , vector
                  , random
                  , mtl
  hs-source-dirs:   src
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -O2

-- ---------------------------------------------------------------------------
-- Executables
-- ---------------------------------------------------------------------------

common exe-common
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , storyteller:gitlib-effect
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , polysemy
                  , polysemy-plugin
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2
                    -fplugin=Polysemy.Plugin

-- | Append a generated story section.
executable story-write
  import:           exe-common
  main-is:          Write.hs
  hs-source-dirs:   app

-- | Copy atoms from a source branch into an entity/tracker branch.
executable story-track
  import:           exe-common
  main-is:          Track.hs
  hs-source-dirs:   app

-- | Split working-tree diffs and merge them into the chain at the right positions.
executable story-rebase
  import:           exe-common
  main-is:          Rebase.hs
  hs-source-dirs:   app

-- | Resolve a scenario template into a character sheet and commit it to an entity branch.
executable story-chargen
  import:           exe-common
  main-is:          CharGen.hs
  hs-source-dirs:   app
  build-depends:    yaml
                  , random


-- | HTTP REST API server.
executable story-server
  import:           exe-common
  main-is:          Server.hs
  hs-source-dirs:   app
  other-modules:    Server.API
                  , Server.Env
                  , Server.Handlers
                  , Server.Run
                  , Server.Types
                  , Server.Util
                  , Server.Agent.Append
                  , Server.Agent.CharGen
                  , Server.Agent.Rebase
                  , Server.Agent.Track
                  , Server.Agent.Write
  build-depends:    servant             >= 0.20
                  , servant-server      >= 0.20
                  , wai
                  , warp
                  , aeson
                  , yaml
                  , random
                  , stm

test-suite storyteller-test
  type:             exitcode-stdio-1.0
  main-is:          Main.hs
  other-modules:    Git.Mock
                  , Paths_storyteller
                  , Storyteller.StorageSpec
                  , Storyteller.SplitDiffMergeSpec
                  , Storyteller.SplitterSpec
                  , Storyteller.TrackerSpec
                  , Storyteller.CharGenSpec
  autogen-modules:  Paths_storyteller
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , storyteller:gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , containers
                  , bytestring
                  , text
                  , runix
                  , hspec >=2.11
                  , QuickCheck >=2.14
                  , hashable
                  , aeson
                  , yaml
  hs-source-dirs:   test
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -fplugin=Polysemy.Plugin
