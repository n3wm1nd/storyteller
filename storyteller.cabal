cabal-version:      3.0
name:               storyteller
version:            0.1.0.0
synopsis:           LLM-powered story development system
description:        Storyteller treats narrative as queryable, versioned state,
                    combining git version control, hierarchical summarization,
                    and character knowledge tracking.
license:            MIT
author:             storyteller authors
maintainer:         authors@storyteller.dev
category:           Development
build-type:         Simple
data-files:         test/fixtures/minimal.yaml

-- | General-purpose git effect + libgit2 interpreter.
--   Intended to migrate to runix proper once stable.
library gitlib-effect
  exposed-modules:  Runix.Git
  build-depends:    base >=4.18 && <5
                  , polysemy
                  , polysemy-plugin
                  , text
                  , bytestring
                  , containers
                  , runix
  hs-source-dirs:   gitlib-effect/src
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs

library
  exposed-modules:  Storyteller
                  , Storyteller.Core.Types
                  , Storyteller.Agent
                  , Storyteller.Core.Storage
                  , Storyteller.Core.Git
                  , Storyteller.Core.Runtime
                  , Storyteller.Core.CLI.Env
                  , Storyteller.Agent.Continuation
                  , Storyteller.Agent.CharContext
                  , Storyteller.Agent.Splitter
                  , Storyteller.Agent.Tracker
                  , Storyteller.Agent.CharGen
                  , Storyteller.Agent.Append
                  , Storyteller.Agent.Write
                  , Storyteller.Agent.FlowWrite
                  , Storyteller.Agent.Fix
                  , Storyteller.Agent.ReplaceTool
                  , Storyteller.Core.Atom
                  , Storyteller.Core.Annotation
                  , Storyteller.Core.Edit
                  , Server.Core.Protocol
                  , Server.Core.Util
                  , Server.Core.Run
                  , Server.Core.Branch
                  , Server.Core.File
                  , Server.Writer.Env
                  , Server.Writer.Notification
                  , Server.Writer.Run
                  , Server.Writer.Session.Protocol
                  , Server.Writer.Session.Connection
                  , Server.Writer.Session.Dispatch
                  , Server.Writer.Branch
                  , Server.Writer.File
                  , Server.Writer.Branch.Protocol
                  , Server.Writer.Branch.Connection
                  , Server.Writer.Branch.Dispatch
                  , Server.Writer.File.Protocol
                  , Server.Writer.File.Connection
                  , Server.Writer.File.Dispatch
  other-modules:
  build-depends:    base >=4.18 && <5
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , array
                  , filepath
                  , polysemy
                  , template-haskell
                  , storyteller:gitlib-effect
                  , polysemy-plugin
                  , aeson
                  , autodocodec
                  , scientific
                  , vector
                  , random
                  , mtl
                  , websockets
                  , wai
                  , warp
                  , wai-websockets
                  , http-types
                  , yaml
                  , stm
  hs-source-dirs:   src
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -O2

-- ---------------------------------------------------------------------------
-- Executables
-- ---------------------------------------------------------------------------

common exe-common
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , storyteller:gitlib-effect
                  , runix
                  , universal-llm
                  , text
                  , bytestring
                  , containers
                  , polysemy
                  , polysemy-plugin
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -O2
                    -fplugin=Polysemy.Plugin

-- | Append a generated story section.
executable story-write
  import:           exe-common
  main-is:          Write.hs
  hs-source-dirs:   app

-- | Copy atoms from a source branch into an entity/tracker branch.
executable story-track
  import:           exe-common
  main-is:          Track.hs
  hs-source-dirs:   app

-- | Split working-tree diffs and merge them into the chain at the right positions.
executable story-rebase
  import:           exe-common
  main-is:          Rebase.hs
  hs-source-dirs:   app

-- | Resolve a scenario template into a character sheet and commit it to an entity branch.
executable story-chargen
  import:           exe-common
  main-is:          CharGen.hs
  hs-source-dirs:   app
  build-depends:    yaml
                  , random


-- | WebSocket server.
executable story-server
  import:           exe-common
  main-is:          Server.hs
  hs-source-dirs:   app
  build-depends:    wai
                  , warp
                  , websockets
                  , wai-websockets
                  , http-types

test-suite storyteller-test
  type:             exitcode-stdio-1.0
  main-is:          Main.hs
  other-modules:    Git.Mock
                  , Paths_storyteller
                  , Storyteller.FileAtomsSpec
                  , Storyteller.StorageSpec
                  , Storyteller.EditSpec
                  , Storyteller.CommitWorkingTreeSpec
                  , Storyteller.SplitterSpec
                  , Storyteller.TrackerSpec
                  , Storyteller.CharGenSpec
                  , Server.TestStack
                  , Server.BranchSpec
                  , Server.FileSpec
                  , Server.NotificationSpec
  autogen-modules:  Paths_storyteller
  build-depends:    base >=4.18 && <5
                  , storyteller
                  , storyteller:gitlib-effect
                  , polysemy
                  , polysemy-plugin
                  , containers
                  , bytestring
                  , text
                  , runix
                  , hspec >=2.11
                  , QuickCheck >=2.14
                  , hashable
                  , aeson
                  , yaml
                  , stm
  hs-source-dirs:   test
  default-language: Haskell2010
  ghc-options:      -Wall
                    -Wcompat
                    -Widentities
                    -Wredundant-constraints
                    -fwarn-tabs
                    -threaded
                    -rtsopts
                    -with-rtsopts=-N
                    -fplugin=Polysemy.Plugin
